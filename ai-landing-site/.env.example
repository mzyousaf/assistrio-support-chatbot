# Backend API origin used for landing fetches and widget runtime.
# Example: http://localhost:3001
NEXT_PUBLIC_API_BASE_URL=

# Server-only key for landing server-side call:
# GET /api/public/landing/bots with header X-API-Key.
LANDING_SITE_BOTS_API_KEY=

# Default/global widget bot id used by AssistrioGlobalEmbed.
NEXT_PUBLIC_LANDING_WIDGET_BOT_ID=

# Default/global widget runtime key for the bot above.
# Required to mount AssistrioGlobalEmbed under current runtime contract.
NEXT_PUBLIC_LANDING_WIDGET_ACCESS_KEY=

