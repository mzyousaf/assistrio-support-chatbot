# --- Put a copy of this file at: ai-landing-site/.env.local (same folder as package.json) ---
# Next.js only loads .env* from THIS app directory. Variables in ai-platform-app/.env or
# ai-platform-backend/.env are NOT used when you run `npm run dev` here.
# After changing NEXT_PUBLIC_* values, stop and restart `next dev` (values are read at startup).

# Backend API origin: bot list proxy, trial API, widget embed, analytics. No trailing slash.
# Example local backend: http://localhost:3001
NEXT_PUBLIC_API_BASE_URL=

# Server-only key for landing server-side call:
# GET /api/public/landing/bots with header X-API-Key.
LANDING_SITE_BOTS_API_KEY=

# Default/global widget bot id used by AssistrioGlobalEmbed.
NEXT_PUBLIC_LANDING_WIDGET_BOT_ID=

# Default/global widget runtime key for the bot above.
# Required to mount AssistrioGlobalEmbed under current runtime contract.
NEXT_PUBLIC_LANDING_WIDGET_ACCESS_KEY=

# Optional: widget bundle URLs. Defaults load from this app’s public/ (/assistrio-chat.js).
# Use the hosted CDN if you do not ship the files in public/:
# NEXT_PUBLIC_ASSISTRIO_WIDGET_JS=https://widget.assistrio.com/assistrio-chat.js
# NEXT_PUBLIC_ASSISTRIO_WIDGET_CSS=https://widget.assistrio.com/assistrio-chat.css

