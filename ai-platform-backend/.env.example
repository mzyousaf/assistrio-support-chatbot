# NODE_ENV: use `development` locally so `/api/widget/preview/*` accepts browser Origin from localhost/127.0.0.1.
# In production, preview requests must come from assistrio.com (and subdomains); bot type (trial/showcase/etc.) does not bypass this.
#
# CORS: comma-separated extra browser origins (e.g. customer sites embedding the widget).
# Production allows https://assistrio.com and *.assistrio.com by default; development allows localhost-style origins only.
# CORS_EXTRA_ORIGINS=https://example.com,https://app.example.com

# OpenAI: used for onboarding and RAG.
# OPENAI_API_KEY=sk-...

# AWS S3 (public bucket): used for avatar and document uploads.
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_PUBLIC_BUCKET=
# Optional: set S3_PUBLIC_ACL=true only if your bucket allows ACL public-read (many buckets block this).
