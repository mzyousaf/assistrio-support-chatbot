# Core server
NODE_ENV=development
PORT=3001

# Database
# MongoDB connection string for backend data.
MONGODB_URI=mongodb://localhost:27017/assistrio

# Auth
# JWT signing secret for dashboard/admin auth.
JWT_SECRET=replace-with-strong-secret

# AI provider
# Default OpenAI key used when a bot does not provide an override.
OPENAI_API_KEY=replace-with-openai-key

# Jobs
# Shared secret for ingestion/job runner callbacks.
JOB_RUNNER_SECRET=replace-with-job-runner-secret

# Optional storage/CDN
# AWS region for uploads (if S3 is enabled).
AWS_REGION=
# S3 bucket name for uploads.
S3_BUCKET=
# Public CDN base URL for served assets (no trailing slash).
CLOUDFRONT_BASE_URL=

# Landing site integration
# Shared key expected in `X-API-Key` for GET /api/public/landing/bots.
LANDING_SITE_BOTS_API_KEY=

# Widget testing helper
# Shared key expected in `X-API-Key` for GET /api/widget/testing/bot.
CHAT_WIDGET_API_KEY=

