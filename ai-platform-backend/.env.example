# Copy to .env — validated by src/config/config.schema.ts (required keys must be set for boot).

# --- Core (required by validation) ---
NODE_ENV=development
PORT=3001
MONGODB_URI=
JWT_SECRET=
OPENAI_API_KEY=
JOB_RUNNER_SECRET=

# --- CORS / server (src/main.ts) ---
# Comma-separated full origins for strict CORS routes. See docs/CORS.md
CORS_EXTRA_ORIGINS=
# 1/true/yes when behind a reverse proxy (real client IP for rate limits)
TRUST_PROXY=

# --- Optional app config (src/config/config.factory.ts) ---
AWS_REGION=
S3_BUCKET=
CLOUDFRONT_BASE_URL=
# Marketing site (assistrio-landing-site): same secret in landing `.env.local` as `NEXT_ASSISTRIO_LANDING_SITE_X_API_KEY`.
# — `X-API-Key` for `GET /api/public/bots`, `GET /api/public/bots/:slug`, document download, and `GET /api/public/landing/bots`
# — `Authorization: Bearer` for `POST /api/landing/trial/request-access` and `POST /api/landing/contact`
LANDING_SITE_X_API_KEY=
# Resend + marketing origin for outbound email (trial magic link + contact form). `LANDING_PUBLIC_SITE_URL` must match the public marketing site (e.g. same value as assistrio-landing-site `NEXT_PUBLIC_SITE_URL`).
RESEND_API_KEY=
LANDING_PUBLIC_SITE_URL=http://localhost:3000
# CONTACT_FROM_EMAIL=Assistrio <onboarding@resend.dev>
# TRIAL_FROM_EMAIL=
# CONTACT_TO_EMAIL=support@assistrio.com
# GET /api/widget/testing/bot — X-API-Key (src/lib/env-var-names.ts)
CHAT_WIDGET_API_KEY=

# --- AWS credentials for uploads (src/lib/s3.ts) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_PUBLIC_BUCKET=
S3_PRIVATE_BUCKET=
# Set true only if bucket allows ACL public-read
S3_PUBLIC_ACL=

# --- Optional tuning ---
# JOBS_RUNNER_LIMIT=5
# SUMMARY_JOBS_RUNNER_LIMIT=5
# CHAT_EMBED_TIMEOUT_MS=
# CHAT_COMPLETION_TIMEOUT_MS=
# CHAT_SUMMARY_TIMEOUT_MS=
# INGESTION_STUCK_TIMEOUT_MINUTES=15


